# Telegram Configuration (REQUIRED)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Web Search API (REQUIRED for weather fetching)
# Get a free Gemini API key from https://aistudio.google.com → Get API Key
# Used by OpenClaw's web_search tool to fetch weather data
GEMINI_API_KEY=your_gemini_api_key_here

# Weather Configuration (OPTIONAL)
# Leave empty for auto-detect, or set to city name or lat,lon
WEATHER_LOCATION=
